{
  "$schema": "https://raw.githubusercontent.com/cloudflare/workers-sdk/main/packages/wrangler/schemas/config/wrangler.json",
  "name": "imessage-dictionary",
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public"
  },
  "compatibility_date": "2025-07-15",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "imessage-dictionary-db",
      "database_id": "7f4b25dc-df31-4bb6-bd51-0cb087cb5201"
    }
  ],
  "routes": [
    { "pattern": "dict.nard.uk", "custom_domain": true }
  ]
}
